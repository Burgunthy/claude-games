{
  "name": "claude-poker",
  "version": "1.0.0",
  "description": "A Texas Hold'em Poker game for Claude Code with AI vs AI mode and visible AI thoughts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "poker": "./bin/poker",
    "claude-poker": "./bin/poker"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/types.d.ts",
      "default": "./dist/core/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:scenario": "tsx tests/parallel/scenario-runner.ts",
    "test:parallel": "bash tests/parallel/run-parallel-tests.sh",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude-games",
    "poker",
    "texas-holdem",
    "cli",
    "game",
    "ai",
    "ai-vs-ai",
    "terminal-game",
    "ink",
    "react"
  ],
  "author": "Claude",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-poker"
  },
  "bugs": {
    "url": "https://github.com/anthropics/claude-poker/issues"
  },
  "homepage": "https://github.com/anthropics/claude-poker#readme",
  "dependencies": {
    "ink": "^4.4.1",
    "@inkjs/ui": "^1.0.0",
    "react": "^18.2.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "oclif": {
    "bin": "poker"
  },
  "vitest": {
    "exclude": [
      "node_modules",
      "dist"
    ]
  }
}
